      "url": "/registry",
      "icons": [{ "src": "/favicon.png", "sizes": "192x192" }]
    },
    {
      "name": "Null Report",
      "short_name": "Null",
      "description": "Report seeing nothing",
      "url": "/null-reports",
      "icons": [{ "src": "/favicon.png", "sizes": "192x192" }]
    },
    {
      "name": "Voice Logger",
